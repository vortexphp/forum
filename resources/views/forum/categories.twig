{% extends 'layouts/default.twig' %}
{% block content %}
<div class="mx-auto max-w-5xl">
    {% set totalThreads = 0 %}
    {% set totalReplies = 0 %}
    {% for category in categories|default([]) %}
        {% set totalThreads = totalThreads + (category.thread_total|default(0)) %}
        {% set totalReplies = totalReplies + (category.reply_total|default(0)) %}
    {% endfor %}

    <section class="relative overflow-hidden rounded-3xl border border-zinc-200 bg-white p-6 shadow-sm dark:border-zinc-800 dark:bg-zinc-900/60 sm:p-8">
        <div class="pointer-events-none absolute -right-20 -top-20 h-64 w-64 rounded-full bg-emerald-400/20 blur-3xl dark:bg-emerald-700/20"></div>
        <div class="pointer-events-none absolute -bottom-24 -left-24 h-56 w-56 rounded-full bg-teal-400/20 blur-3xl dark:bg-teal-700/20"></div>
        <div class="relative flex flex-wrap items-start justify-between gap-6">
            <div class="max-w-2xl">
                <p class="inline-flex items-center gap-2 rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-300">
                    <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                    VortexForum Community
                </p>
                <h1 class="mt-4 text-3xl font-semibold tracking-tight text-zinc-900 dark:text-white sm:text-4xl">{{ trans('forum.categories.title') }}</h1>
                <p class="mt-3 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">{{ trans('forum.categories.subtitle') }}</p>
                <div class="mt-5 flex flex-wrap items-center gap-2">
                    <a href="{{ route('forum.index') }}#categories" class="inline-flex items-center gap-2 rounded-xl bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500">
                        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"></path></svg>
                        Explore categories
                    </a>
                    {% if authUser is null %}
                        <a href="/register" class="inline-flex items-center gap-2 rounded-xl border border-zinc-300 bg-white px-4 py-2 text-sm font-semibold text-zinc-700 transition hover:border-emerald-500 hover:text-emerald-700 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-300 dark:hover:border-emerald-500 dark:hover:text-emerald-300">
                            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"></path></svg>
                            Join VortexForum
                        </a>
                    {% endif %}
                </div>
            </div>
            <div class="grid w-full max-w-md grid-cols-2 gap-3">
                <div class="rounded-2xl border border-zinc-200 bg-zinc-50/80 p-4 dark:border-zinc-700 dark:bg-zinc-800/50">
                    <p class="text-xs font-medium text-zinc-500 dark:text-zinc-400">Categories</p>
                    <p class="mt-1 text-2xl font-semibold text-zinc-900 dark:text-white">{{ categories|length }}</p>
                </div>
                <div class="rounded-2xl border border-zinc-200 bg-zinc-50/80 p-4 dark:border-zinc-700 dark:bg-zinc-800/50">
                    <p class="text-xs font-medium text-zinc-500 dark:text-zinc-400">Threads</p>
                    <p class="mt-1 text-2xl font-semibold text-zinc-900 dark:text-white">{{ totalThreads }}</p>
                </div>
                <div class="rounded-2xl border border-zinc-200 bg-zinc-50/80 p-4 dark:border-zinc-700 dark:bg-zinc-800/50">
                    <p class="text-xs font-medium text-zinc-500 dark:text-zinc-400">Replies</p>
                    <p class="mt-1 text-2xl font-semibold text-zinc-900 dark:text-white">{{ totalReplies }}</p>
                </div>
                <div class="rounded-2xl border border-zinc-200 bg-zinc-50/80 p-4 dark:border-zinc-700 dark:bg-zinc-800/50">
                    <p class="text-xs font-medium text-zinc-500 dark:text-zinc-400">Shortcut</p>
                    <p class="mt-1 text-sm font-semibold text-zinc-900 dark:text-white">Press <span class="rounded border border-zinc-300 px-1.5 py-0.5 text-[11px] dark:border-zinc-600">/</span> to search</p>
                </div>
            </div>
        </div>
    </section>

    {% if categories is empty %}
        <div class="mt-6 rounded-2xl border border-zinc-200 bg-white p-8 text-sm text-zinc-600 dark:border-zinc-800 dark:bg-zinc-900/60 dark:text-zinc-400">
            {{ trans('forum.categories.empty') }}
        </div>
    {% else %}
        <section id="categories" class="mt-6">
            <div class="mb-3 flex items-center justify-between gap-3">
                <h2 class="text-lg font-semibold text-zinc-900 dark:text-white">Browse all categories</h2>
                <p class="text-xs text-zinc-500 dark:text-zinc-400">{{ categories|length }} listed</p>
            </div>
        <div class="grid gap-4 sm:grid-cols-2">
            {% for category in categories %}
                <a href="{{ route('forum.category', { category: category.slug }) }}" class="block rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:border-emerald-500/40 hover:shadow-md dark:border-zinc-800 dark:bg-zinc-900/60 dark:hover:border-emerald-500/30" style="border-top-width:3px;border-top-color:{{ category.color|default('#10b981') }};">
                    <div class="flex items-start justify-between gap-4">
                        <div>
                            <h2 class="text-lg font-semibold text-zinc-900 dark:text-white">
                                <span class="mr-2 inline-flex h-8 w-8 items-center justify-center rounded-lg text-base" style="background-color: color-mix(in oklab, {{ category.color|default('#10b981') }} 18%, white); color: {{ category.color|default('#10b981') }};" aria-hidden="true">{{ category.icon|default('💬') }}</span>{{ category.name }}
                            </h2>
                            {% if category.description is not empty %}
                                <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400">{{ category.description }}</p>
                            {% endif %}
                        </div>
                        {% if category.is_locked %}
                            <span class="rounded-full bg-amber-100 px-2.5 py-1 text-xs font-semibold text-amber-800 dark:bg-amber-900/40 dark:text-amber-300">{{ trans('forum.categories.locked_badge') }}</span>
                        {% endif %}
                    </div>
                    <div class="mt-4 flex flex-wrap items-center gap-2 text-xs text-zinc-500 dark:text-zinc-400">
                        <span>{{ trans('forum.categories.thread_total', { count: category.thread_total|default(0) }) }}</span>
                        <span>·</span>
                        <span>{{ trans('forum.categories.reply_total', { count: category.reply_total|default(0) }) }}</span>
                        {% if category.last_post_at %}
                            <span>·</span>
                            <span>{{ trans('forum.categories.last_activity') }} {{ category.last_post_at }}</span>
                        {% endif %}
                    </div>
                </a>
            {% endfor %}
        </div>
        </section>
    {% endif %}

    {% if pagination is defined and pagination.hasPages() %}
        <div class="mt-6 flex items-center justify-between text-sm">
            {% if not pagination.onFirstPage() %}
                <a href="{{ pagination.urlForPage(pagination.page - 1) }}" class="rounded-lg border border-zinc-300 px-3 py-1.5 text-zinc-700 hover:border-emerald-500 hover:text-emerald-700 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-emerald-500 dark:hover:text-emerald-400">
                    {{ trans('forum.pagination.prev') }}
                </a>
            {% else %}
                <span></span>
            {% endif %}
            <span class="text-zinc-500 dark:text-zinc-500">{{ trans('forum.pagination.summary', { page: pagination.page, last: pagination.last_page, total: pagination.total }) }}</span>
            {% if not pagination.onLastPage() %}
                <a href="{{ pagination.urlForPage(pagination.page + 1) }}" class="rounded-lg border border-zinc-300 px-3 py-1.5 text-zinc-700 hover:border-emerald-500 hover:text-emerald-700 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-emerald-500 dark:hover:text-emerald-400">
                    {{ trans('forum.pagination.next') }}
                </a>
            {% else %}
                <span></span>
            {% endif %}
        </div>
    {% endif %}
</div>
{% endblock %}
