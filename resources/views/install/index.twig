{% extends 'layouts/default.twig' %}

{% block content %}
    <div class="mx-auto max-w-2xl">
        <div class="rounded-2xl border border-zinc-200 bg-white p-6 shadow-sm dark:border-zinc-800 dark:bg-zinc-900">
            <h1 class="text-2xl font-semibold tracking-tight text-zinc-900 dark:text-white">Install Forum</h1>
            <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-300">
                The forum database is not initialized yet. Run the installer to apply all migrations.
            </p>

            {% if status is defined and status %}
                <div class="mt-4 rounded-lg border border-emerald-200 bg-emerald-50 px-3 py-2 text-sm text-emerald-800 dark:border-emerald-900/50 dark:bg-emerald-950/50 dark:text-emerald-200">
                    {{ status }}
                </div>
            {% endif %}

            {% if errors is defined and errors %}
                <div class="mt-4 rounded-lg border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-800 dark:border-rose-900/50 dark:bg-rose-950/50 dark:text-rose-200">
                    {% for key, message in errors %}
                        <p>{{ message }}</p>
                    {% endfor %}
                </div>
            {% endif %}

            <form method="post" action="{{ route('install.run') }}" class="mt-5 space-y-4">
                <input type="hidden" name="_csrf" value="{{ csrfToken|default('') }}">
                <div>
                    <label for="forum_title" class="mb-1.5 block text-sm font-medium text-zinc-700 dark:text-zinc-200">Forum title</label>
                    <input id="forum_title" name="forum_title" type="text" value="{{ old.forum_title|default('') }}" maxlength="120" required class="w-full rounded-lg border border-zinc-300 bg-white px-3 py-2 text-sm text-zinc-900 outline-none transition focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100">
                    {% if errors.forum_title is defined %}<p class="mt-1 text-sm text-rose-600">{{ errors.forum_title }}</p>{% endif %}
                </div>
                <div>
                    <label for="forum_description" class="mb-1.5 block text-sm font-medium text-zinc-700 dark:text-zinc-200">Forum description</label>
                    <textarea id="forum_description" name="forum_description" maxlength="500" rows="3" required class="w-full rounded-lg border border-zinc-300 bg-white px-3 py-2 text-sm text-zinc-900 outline-none transition focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100">{{ old.forum_description|default('') }}</textarea>
                    {% if errors.forum_description is defined %}<p class="mt-1 text-sm text-rose-600">{{ errors.forum_description }}</p>{% endif %}
                </div>
                <div class="grid gap-4 sm:grid-cols-2">
                    <div>
                        <label for="admin_username" class="mb-1.5 block text-sm font-medium text-zinc-700 dark:text-zinc-200">Admin username</label>
                        <input id="admin_username" name="admin_username" type="text" value="{{ old.admin_username|default('') }}" maxlength="120" required class="w-full rounded-lg border border-zinc-300 bg-white px-3 py-2 text-sm text-zinc-900 outline-none transition focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100">
                        {% if errors.admin_username is defined %}<p class="mt-1 text-sm text-rose-600">{{ errors.admin_username }}</p>{% endif %}
                    </div>
                    <div>
                        <label for="admin_password" class="mb-1.5 block text-sm font-medium text-zinc-700 dark:text-zinc-200">Admin password</label>
                        <input id="admin_password" name="admin_password" type="password" minlength="8" required class="w-full rounded-lg border border-zinc-300 bg-white px-3 py-2 text-sm text-zinc-900 outline-none transition focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100">
                        {% if errors.admin_password is defined %}<p class="mt-1 text-sm text-rose-600">{{ errors.admin_password }}</p>{% endif %}
                    </div>
                </div>
                <div>
                    <label for="admin_password_confirmation" class="mb-1.5 block text-sm font-medium text-zinc-700 dark:text-zinc-200">Confirm admin password</label>
                    <input id="admin_password_confirmation" name="admin_password_confirmation" type="password" minlength="8" required class="w-full rounded-lg border border-zinc-300 bg-white px-3 py-2 text-sm text-zinc-900 outline-none transition focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100">
                    {% if errors.admin_password_confirmation is defined %}<p class="mt-1 text-sm text-rose-600">{{ errors.admin_password_confirmation }}</p>{% endif %}
                </div>
                <label class="flex items-start gap-2 rounded-lg border border-zinc-200 px-3 py-2 text-sm text-zinc-700 dark:border-zinc-700 dark:text-zinc-200">
                    <input type="checkbox" name="include_default_content" value="1" {{ old.include_default_content|default(false) ? 'checked' : '' }} class="mt-0.5 rounded border-zinc-300 text-emerald-600 focus:ring-emerald-500">
                    <span>
                        <strong>Include default content</strong><br>
                        Seed categories, demo users, sample threads, posts, and likes.
                    </span>
                </label>
                <button
                    type="submit"
                    class="inline-flex items-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500"
                >
                    Run installation
                </button>
            </form>
        </div>
    </div>
{% endblock %}
