{% extends 'layouts/default.twig' %}
{% block content %}
<div class="mx-auto max-w-4xl">
    <header class="rounded-2xl border border-zinc-200 bg-white p-5 dark:border-zinc-800 dark:bg-zinc-900/60">
        <h1 class="text-2xl font-semibold text-zinc-900 dark:text-white">{{ trans('notifications.title') }}</h1>
        <p class="mt-2 text-sm text-zinc-500 dark:text-zinc-400">{{ trans('notifications.subtitle') }}</p>
    </header>

    <section class="mt-4 space-y-3">
        {% for item in notifications %}
            {% set targetUrl = item.url|default('') %}
            {% if targetUrl %}
                <a href="{{ targetUrl }}" class="block rounded-xl border border-zinc-200 bg-white p-4 transition hover:border-emerald-500 dark:border-zinc-800 dark:bg-zinc-900/60 dark:hover:border-emerald-500">
            {% else %}
                <div class="rounded-xl border border-zinc-200 bg-white p-4 dark:border-zinc-800 dark:bg-zinc-900/60">
            {% endif %}
                <div class="flex items-start justify-between gap-3">
                    <div class="min-w-0">
                        <p class="text-sm font-semibold text-zinc-900 dark:text-white">{{ item.title }}</p>
                        {% if item.body is defined and item.body %}
                            <p class="mt-1 text-sm text-zinc-600 dark:text-zinc-400">{{ item.body }}</p>
                        {% endif %}
                    </div>
                    <span class="shrink-0 text-xs text-zinc-500 dark:text-zinc-500">{{ item.created_at }}</span>
                </div>
            {% if targetUrl %}
                </a>
            {% else %}
                </div>
            {% endif %}
        {% else %}
            <div class="rounded-xl border border-zinc-200 bg-white p-6 text-sm text-zinc-600 dark:border-zinc-800 dark:bg-zinc-900/60 dark:text-zinc-400">
                {{ trans('notifications.empty') }}
            </div>
        {% endfor %}
    </section>

    {% if pagination.hasPages() %}
        <div class="mt-6 flex items-center justify-between text-sm">
            {% if not pagination.onFirstPage() %}
                <a href="{{ pagination.urlForPage(pagination.page - 1) }}" class="rounded-lg border border-zinc-300 px-3 py-1.5 text-zinc-700 hover:border-emerald-500 hover:text-emerald-700 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-emerald-500 dark:hover:text-emerald-400">
                    {{ trans('forum.pagination.prev') }}
                </a>
            {% else %}
                <span></span>
            {% endif %}
            <span class="text-zinc-500 dark:text-zinc-500">{{ trans('forum.pagination.summary', { page: pagination.page, last: pagination.last_page, total: pagination.total }) }}</span>
            {% if not pagination.onLastPage() %}
                <a href="{{ pagination.urlForPage(pagination.page + 1) }}" class="rounded-lg border border-zinc-300 px-3 py-1.5 text-zinc-700 hover:border-emerald-500 hover:text-emerald-700 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-emerald-500 dark:hover:text-emerald-400">
                    {{ trans('forum.pagination.next') }}
                </a>
            {% else %}
                <span></span>
            {% endif %}
        </div>
    {% endif %}
</div>
{% endblock %}
