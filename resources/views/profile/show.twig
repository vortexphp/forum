{% extends 'layouts/default.twig' %}
{% block content %}
<div class="mx-auto max-w-5xl">
    <div class="relative overflow-hidden rounded-3xl border border-zinc-200 bg-white p-6 shadow-sm dark:border-zinc-800 dark:bg-zinc-900/60 sm:p-8">
        <div class="pointer-events-none absolute -right-20 -top-20 h-56 w-56 rounded-full bg-emerald-400/20 blur-3xl dark:bg-emerald-700/20"></div>
        {% if authUser is not null %}
            <a href="{{ route('messages.inbox') }}" class="absolute right-4 top-4 inline-flex items-center gap-2 rounded-full border border-emerald-200 bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-800 shadow-sm dark:border-emerald-900/40 dark:bg-emerald-900/20 dark:text-emerald-300">
                <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                {{ trans('messages.inbox.unread', { count: unreadMessagesCount|default(0) }) }}
            </a>
        {% endif %}
        <div class="relative flex flex-wrap items-start justify-between gap-4">
            <div class="flex min-w-0 items-center gap-4">
                {% if profileUser.avatar is defined and profileUser.avatar %}
                    <img src="{{ public_url(profileUser.avatar) }}" alt="{{ profileUser.name }}" class="h-20 w-20 rounded-2xl object-cover ring-4 ring-white shadow-md dark:ring-zinc-800" width="80" height="80">
                {% else %}
                    <span class="inline-flex h-20 w-20 items-center justify-center rounded-2xl text-2xl font-semibold text-white ring-4 ring-white shadow-md dark:ring-zinc-800" style="background-color: {{ profileUser.name|avatar_color }}">{{ profileUser.name|slice(0,1)|upper }}</span>
                {% endif %}
                <div class="min-w-0">
                    <p class="inline-flex items-center gap-1 rounded-full bg-emerald-100 px-2.5 py-1 text-[11px] font-semibold uppercase tracking-wide text-emerald-700 dark:bg-emerald-900/25 dark:text-emerald-300">
                        <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M2 12h20"></path></svg>
                        Community Member
                    </p>
                    <h1 class="mt-2 truncate text-2xl font-semibold text-zinc-900 dark:text-white">{{ profileUser.name }}</h1>
                    <p class="mt-1 inline-flex items-center gap-1.5 text-sm text-zinc-500 dark:text-zinc-400">
                        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="16" rx="2"></rect><path d="M16 3v4M8 3v4M3 11h18"></path></svg>
                        {{ trans('profile.member_since') }} {{ profileUser.created_at }}
                    </p>
                </div>
            </div>
            {% if authUser is not null and authUser.id != profileUser.id %}
                <a href="{{ route('messages.show', { user: profileUser.id }) }}" class="inline-flex items-center gap-2 rounded-xl border border-zinc-300 bg-white px-4 py-2 text-xs font-semibold text-zinc-700 shadow-sm transition hover:border-emerald-500 hover:text-emerald-700 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-300 dark:hover:border-emerald-500 dark:hover:text-emerald-300">
                    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                    {{ trans('profile.send_message') }}
                </a>
            {% endif %}
        </div>
        {% if badges is not empty %}
            <div class="relative mt-5 flex flex-wrap gap-2">
                {% for badge in badges %}
                    <span class="inline-flex items-center gap-1.5 rounded-full bg-sky-100 px-2.5 py-1 text-xs font-semibold text-sky-800 dark:bg-sky-900/35 dark:text-sky-300">
                        <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 12 2 2 4-4"></path><circle cx="12" cy="12" r="9"></circle></svg>
                        {{ trans('badges.' ~ badge) }}
                    </span>
                {% endfor %}
            </div>
        {% endif %}
    </div>

    <div class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-5">
        <div class="rounded-2xl border border-zinc-200 bg-white p-4 shadow-sm dark:border-zinc-800 dark:bg-zinc-900/60">
            <p class="inline-flex items-center gap-1.5 text-xs text-zinc-500">
                <svg class="h-3.5 w-3.5 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
                {{ trans('profile.stats.threads') }}
            </p>
            <p class="mt-1 text-2xl font-semibold text-zinc-900 dark:text-white">{{ stats.threads_count }}</p>
        </div>
        <div class="rounded-2xl border border-zinc-200 bg-white p-4 shadow-sm dark:border-zinc-800 dark:bg-zinc-900/60">
            <p class="inline-flex items-center gap-1.5 text-xs text-zinc-500">
                <svg class="h-3.5 w-3.5 text-blue-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                {{ trans('profile.stats.posts') }}
            </p>
            <p class="mt-1 text-2xl font-semibold text-zinc-900 dark:text-white">{{ stats.posts_count }}</p>
        </div>
        <div class="rounded-2xl border border-zinc-200 bg-white p-4 shadow-sm dark:border-zinc-800 dark:bg-zinc-900/60">
            <p class="inline-flex items-center gap-1.5 text-xs text-zinc-500">
                <svg class="h-3.5 w-3.5 text-rose-600" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21s-7.2-4.35-9.6-8.7C.18 8.1 2.58 3 7.5 3c2.13 0 3.45 1.11 4.5 2.55C13.05 4.11 14.37 3 16.5 3c4.92 0 7.32 5.1 5.1 9.3C19.2 16.65 12 21 12 21z"></path></svg>
                {{ trans('profile.stats.likes_received') }}
            </p>
            <p class="mt-1 text-2xl font-semibold text-zinc-900 dark:text-white">{{ stats.likes_received }}</p>
        </div>
        <div class="rounded-2xl border border-zinc-200 bg-white p-4 shadow-sm dark:border-zinc-800 dark:bg-zinc-900/60">
            <p class="inline-flex items-center gap-1.5 text-xs text-zinc-500">
                <svg class="h-3.5 w-3.5 text-amber-600" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21s-7.2-4.35-9.6-8.7C.18 8.1 2.58 3 7.5 3c2.13 0 3.45 1.11 4.5 2.55C13.05 4.11 14.37 3 16.5 3c4.92 0 7.32 5.1 5.1 9.3C19.2 16.65 12 21 12 21z"></path></svg>
                {{ trans('profile.stats.likes_given') }}
            </p>
            <p class="mt-1 text-2xl font-semibold text-zinc-900 dark:text-white">{{ stats.likes_given }}</p>
        </div>
        <div class="rounded-2xl border border-zinc-200 bg-white p-4 shadow-sm dark:border-zinc-800 dark:bg-zinc-900/60">
            <p class="inline-flex items-center gap-1.5 text-xs text-zinc-500">
                <svg class="h-3.5 w-3.5 text-violet-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2 4 5v6c0 5 3.5 9.74 8 11 4.5-1.26 8-6 8-11V5l-8-3z"></path><path d="m9 12 2 2 4-4"></path></svg>
                {{ trans('profile.stats.flags_received') }}
            </p>
            <p class="mt-1 text-2xl font-semibold text-zinc-900 dark:text-white">{{ stats.flags_received }}</p>
        </div>
    </div>

    <div class="mt-8 grid gap-6 lg:grid-cols-2">
        <section class="rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm dark:border-zinc-800 dark:bg-zinc-900/60">
            <h2 class="inline-flex items-center gap-2 text-lg font-semibold text-zinc-900 dark:text-white">
                <svg class="h-5 w-5 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
                {{ trans('profile.recent_threads') }}
            </h2>
            <div class="mt-4 space-y-3">
                {% for thread in recentThreads %}
                    <a href="{{ route('forum.thread.show', { category: thread.category_slug, thread: thread.slug }) }}" class="group block rounded-xl border border-zinc-200 px-3 py-2.5 text-sm text-zinc-700 transition hover:border-emerald-500 hover:bg-emerald-50/50 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-emerald-500 dark:hover:bg-emerald-900/10">
                        <p class="font-semibold group-hover:text-emerald-700 dark:group-hover:text-emerald-300">{{ thread.title }}</p>
                        <p class="mt-1 inline-flex items-center gap-1.5 text-xs text-zinc-500 dark:text-zinc-500">
                            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M12 3v18"></path></svg>
                            {{ thread.category_name }} · {{ thread.created_at }}
                        </p>
                    </a>
                {% else %}
                    <p class="rounded-xl border border-dashed border-zinc-300 p-4 text-sm text-zinc-500 dark:border-zinc-700 dark:text-zinc-400">{{ trans('profile.empty_threads') }}</p>
                {% endfor %}
            </div>
        </section>

        <section class="rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm dark:border-zinc-800 dark:bg-zinc-900/60">
            <h2 class="inline-flex items-center gap-2 text-lg font-semibold text-zinc-900 dark:text-white">
                <svg class="h-5 w-5 text-blue-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                {{ trans('profile.recent_posts') }}
            </h2>
            <div class="mt-4 space-y-3">
                {% for post in recentPosts %}
                    <a href="{{ route('forum.thread.show', { category: post.category_slug, thread: post.thread_slug }) }}#comments" class="group block rounded-xl border border-zinc-200 px-3 py-2.5 text-sm text-zinc-700 transition hover:border-emerald-500 hover:bg-emerald-50/50 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-emerald-500 dark:hover:bg-emerald-900/10">
                        <p class="line-clamp-2">{{ post.body }}</p>
                        <p class="mt-1 inline-flex items-center gap-1.5 text-xs text-zinc-500 dark:text-zinc-500">
                            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="16" rx="2"></rect><path d="M16 3v4M8 3v4M3 11h18"></path></svg>
                            {{ post.thread_title }} · {{ post.created_at }}
                        </p>
                    </a>
                {% else %}
                    <p class="rounded-xl border border-dashed border-zinc-300 p-4 text-sm text-zinc-500 dark:border-zinc-700 dark:text-zinc-400">{{ trans('profile.empty_posts') }}</p>
                {% endfor %}
            </div>
        </section>
    </div>
</div>
{% endblock %}
