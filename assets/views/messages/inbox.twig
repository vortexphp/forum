{% extends 'layouts/default.twig' %}
{% block content %}
<div class="mx-auto max-w-4xl">
    <header class="rounded-2xl border border-zinc-200 bg-white p-5 dark:border-zinc-800 dark:bg-zinc-900/60">
        <h1 class="text-2xl font-semibold text-zinc-900 dark:text-white">{{ trans('messages.inbox.title') }}</h1>
        <p class="mt-2 text-sm text-zinc-500 dark:text-zinc-400">
            {{ trans('messages.inbox.unread', { count: unreadCount|default(0) }) }}
        </p>
    </header>

    {% if status %}
        <div class="mt-4 rounded-lg border border-emerald-300 bg-emerald-50 p-3 text-sm text-emerald-800 dark:border-emerald-900/40 dark:bg-emerald-900/20 dark:text-emerald-300">{{ status }}</div>
    {% endif %}

    <section class="mt-4 space-y-3">
        {% for convo in conversations %}
            <a href="{{ route('messages.show', { user: convo.other_user_id }) }}" class="block rounded-xl border border-zinc-200 bg-white p-4 hover:border-emerald-500 dark:border-zinc-800 dark:bg-zinc-900/60 dark:hover:border-emerald-500">
                <div class="flex items-start justify-between gap-3">
                    <div class="min-w-0">
                        <p class="text-sm font-semibold text-zinc-900 dark:text-white">
                            {{ convo.other_user_name }}
                            {% if convo.unread_count|default(0) > 0 %}
                                <span class="ml-2 rounded-full bg-emerald-100 px-2 py-0.5 text-[11px] font-semibold text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-300">{{ trans('messages.inbox.unread_badge', { count: convo.unread_count }) }}</span>
                            {% endif %}
                        </p>
                        <p class="mt-1 line-clamp-1 text-sm text-zinc-600 dark:text-zinc-400">{{ convo.last_body }}</p>
                    </div>
                    <span class="shrink-0 text-xs text-zinc-500 dark:text-zinc-500">{{ convo.last_created_at }}</span>
                </div>
            </a>
        {% else %}
            <div class="rounded-xl border border-zinc-200 bg-white p-6 text-sm text-zinc-600 dark:border-zinc-800 dark:bg-zinc-900/60 dark:text-zinc-400">
                {{ trans('messages.inbox.empty') }}
            </div>
        {% endfor %}
    </section>

    {% if pagination.hasPages() %}
        <div class="mt-6 flex items-center justify-between text-sm">
            {% if not pagination.onFirstPage() %}
                <a href="{{ pagination.urlForPage(pagination.page - 1) }}" class="rounded-lg border border-zinc-300 px-3 py-1.5 text-zinc-700 hover:border-emerald-500 hover:text-emerald-700 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-emerald-500 dark:hover:text-emerald-400">
                    {{ trans('forum.pagination.prev') }}
                </a>
            {% else %}
                <span></span>
            {% endif %}
            <span class="text-zinc-500 dark:text-zinc-500">{{ trans('forum.pagination.summary', { page: pagination.page, last: pagination.last_page, total: pagination.total }) }}</span>
            {% if not pagination.onLastPage() %}
                <a href="{{ pagination.urlForPage(pagination.page + 1) }}" class="rounded-lg border border-zinc-300 px-3 py-1.5 text-zinc-700 hover:border-emerald-500 hover:text-emerald-700 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-emerald-500 dark:hover:text-emerald-400">
                    {{ trans('forum.pagination.next') }}
                </a>
            {% else %}
                <span></span>
            {% endif %}
        </div>
    {% endif %}
</div>
{% endblock %}
