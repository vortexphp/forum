<article class="rounded-xl border border-zinc-200 bg-white p-4 dark:border-zinc-800 dark:bg-zinc-900/60">
    <div class="flex items-start justify-between gap-3">
        <div class="min-w-0 flex items-start gap-3">
            {% if post.author_avatar is defined and post.author_avatar %}
                <a href="{{ route('profile.show', { user: post.user_id }) }}">
                    <img src="{{ public_url(post.author_avatar) }}" alt="{{ post.author_name }}" class="h-9 w-9 shrink-0 rounded-full object-cover ring-1 ring-zinc-200 dark:ring-zinc-700" width="36" height="36">
                </a>
            {% else %}
                <a href="{{ route('profile.show', { user: post.user_id }) }}" class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full text-xs font-semibold text-white" style="background-color: {{ post.author_name|avatar_color }}">{{ post.author_name|slice(0, 1)|upper }}</a>
            {% endif %}
            <div>
                <p class="text-sm font-semibold text-zinc-900 dark:text-white">
                    <a href="{{ route('profile.show', { user: post.user_id }) }}" class="hover:text-emerald-600 dark:hover:text-emerald-400">{{ post.author_name }}</a>
                    {% if post.author_primary_badge is defined and post.author_primary_badge %}
                        <span class="ml-1 rounded bg-sky-100 px-1.5 py-0.5 text-[11px] font-semibold text-sky-800 dark:bg-sky-900/35 dark:text-sky-300">{{ trans('badges.' ~ post.author_primary_badge) }}</span>
                    {% elseif post.author_role == 'moderator' %}
                        <span class="ml-1 rounded bg-violet-100 px-1.5 py-0.5 text-[11px] font-semibold text-violet-800 dark:bg-violet-900/35 dark:text-violet-300">{{ trans('forum.moderation.badge') }}</span>
                    {% endif %}
                </p>
                <p class="text-xs text-zinc-500 dark:text-zinc-500">{{ post.created_at }}</p>
            </div>
        </div>
        <div class="flex flex-wrap items-center gap-2 text-xs">
            {% if authUser is not null %}
                <form method="post" action="{{ route('forum.post.like', { category: category.slug, thread: thread.slug, post: post.id }) }}" data-like-form>
                    <input type="hidden" name="_csrf" value="{{ csrfToken|default('') }}">
                    <button
                        type="submit"
                        data-like-button
                        data-liked="{{ post.liked_by_auth_user ? '1' : '0' }}"
                        data-label-like="{{ trans('forum.likes.button') }}"
                        class="inline-flex items-center gap-1.5 rounded border px-2 py-1 {{ post.liked_by_auth_user ? 'border-emerald-500 text-emerald-700 dark:border-emerald-500 dark:text-emerald-300' : 'border-zinc-300 text-zinc-700 dark:border-zinc-700 dark:text-zinc-300' }}"
                    >
                        <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 10v10"></path><path d="M12 10v10"></path><path d="M17 10v10"></path><path d="M5 10h14"></path><path d="M10 10V6a2 2 0 0 1 2-2h0a2 2 0 0 1 2 2v4"></path></svg>
                        <span>{{ trans('forum.likes.button') }} ({{ post.likes_count|default(0) }})</span>
                    </button>
                </form>
                <form method="post" action="{{ route('forum.flag.post', { category: category.slug, thread: thread.slug, post: post.id }) }}">
                    <input type="hidden" name="_csrf" value="{{ csrfToken|default('') }}">
                    <input type="hidden" name="reason" value="post">
                    <button type="submit" class="inline-flex items-center gap-1.5 rounded border border-zinc-300 px-2 py-1 text-zinc-700 hover:border-amber-500 hover:text-amber-700 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-amber-500 dark:hover:text-amber-300">
                        <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 3v18"></path><path d="M8 4h11l-2.5 4 2.5 4H8"></path></svg>
                        {{ trans('forum.flags.flag_post') }}
                    </button>
                </form>
            {% else %}
                <span class="rounded border border-zinc-300 px-2 py-1 text-zinc-500 dark:border-zinc-700 dark:text-zinc-400">{{ trans('forum.likes.button') }} ({{ post.likes_count|default(0) }})</span>
            {% endif %}
            {% if authUser is not null and ((authUser.id == post.user_id) or authUser.role == 'moderator') %}
                <a href="{{ route('forum.post.edit', { category: category.slug, thread: thread.slug, post: post.id }) }}" class="inline-flex items-center gap-1.5 rounded border border-zinc-300 px-2 py-1 text-zinc-700 hover:border-emerald-500 hover:text-emerald-700 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-emerald-500 dark:hover:text-emerald-400">
                    <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"></path><path d="m16.5 3.5 4 4L8 20l-5 1 1-5Z"></path></svg>
                    {{ trans('forum.post.edit') }}
                </a>
            {% endif %}
            {% if authUser is not null and authUser.role == 'moderator' %}
                <form method="post" action="{{ route('forum.moderation.delete_post', { category: category.slug, thread: thread.slug, post: post.id }) }}" data-confirm-message="{{ trans('forum.moderation.confirm_delete_post') }}">
                    <input type="hidden" name="_csrf" value="{{ csrfToken|default('') }}">
                    <button type="submit" class="rounded border border-rose-300 px-2 py-1 text-rose-700 hover:bg-rose-50 dark:border-rose-900/40 dark:text-rose-300 dark:hover:bg-rose-900/20">
                        {{ trans('forum.moderation.delete_post') }}
                    </button>
                </form>
            {% endif %}
        </div>
    </div>
    <div class="prose prose-zinc mt-3 max-w-none text-sm dark:prose-invert">{{ post.body_html|raw }}</div>
    {% if post.is_edited %}
        <p class="mt-3 text-xs text-zinc-500 dark:text-zinc-500">{{ trans('forum.post.edited') }} {{ post.edited_at }}</p>
    {% endif %}
</article>
