<article class="rounded-xl border border-zinc-200 bg-white p-4 dark:border-zinc-800 dark:bg-zinc-900/60">
    <div class="flex items-start justify-between gap-3">
        <div class="min-w-0">
            <p class="text-sm font-semibold text-zinc-900 dark:text-white">
                {{ post.author_name }}
                {% if post.author_role == 'moderator' %}
                    <span class="ml-1 rounded bg-violet-100 px-1.5 py-0.5 text-[11px] font-semibold text-violet-800 dark:bg-violet-900/35 dark:text-violet-300">{{ trans('forum.moderation.badge') }}</span>
                {% endif %}
            </p>
            <p class="text-xs text-zinc-500 dark:text-zinc-500">{{ post.created_at }}</p>
        </div>
        <div class="flex flex-wrap items-center gap-2 text-xs">
            {% if authUser is not null %}
                <form method="post" action="{{ route('forum.post.like', { category: category.slug, thread: thread.slug, post: post.id }) }}">
                    <input type="hidden" name="_csrf" value="{{ csrfToken|default('') }}">
                    <button type="submit" class="rounded border px-2 py-1 {{ post.liked_by_auth_user ? 'border-emerald-500 text-emerald-700 dark:border-emerald-500 dark:text-emerald-300' : 'border-zinc-300 text-zinc-700 dark:border-zinc-700 dark:text-zinc-300' }}">
                        {{ trans('forum.likes.button') }} ({{ post.likes_count|default(0) }})
                    </button>
                </form>
                <form method="post" action="{{ route('forum.flag.post', { category: category.slug, thread: thread.slug, post: post.id }) }}">
                    <input type="hidden" name="_csrf" value="{{ csrfToken|default('') }}">
                    <input type="hidden" name="reason" value="post">
                    <button type="submit" class="rounded border border-zinc-300 px-2 py-1 text-zinc-700 hover:border-amber-500 hover:text-amber-700 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-amber-500 dark:hover:text-amber-300">
                        {{ trans('forum.flags.flag_post') }}
                    </button>
                </form>
            {% else %}
                <span class="rounded border border-zinc-300 px-2 py-1 text-zinc-500 dark:border-zinc-700 dark:text-zinc-400">{{ trans('forum.likes.button') }} ({{ post.likes_count|default(0) }})</span>
            {% endif %}
            {% if authUser is not null and ((authUser.id == post.user_id) or authUser.role == 'moderator') %}
                <a href="{{ route('forum.post.edit', { category: category.slug, thread: thread.slug, post: post.id }) }}" class="rounded border border-zinc-300 px-2 py-1 text-zinc-700 hover:border-emerald-500 hover:text-emerald-700 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-emerald-500 dark:hover:text-emerald-400">
                    {{ trans('forum.post.edit') }}
                </a>
            {% endif %}
            {% if authUser is not null and authUser.role == 'moderator' %}
                <form method="post" action="{{ route('forum.moderation.delete_post', { category: category.slug, thread: thread.slug, post: post.id }) }}">
                    <input type="hidden" name="_csrf" value="{{ csrfToken|default('') }}">
                    <button type="submit" class="rounded border border-rose-300 px-2 py-1 text-rose-700 hover:bg-rose-50 dark:border-rose-900/40 dark:text-rose-300 dark:hover:bg-rose-900/20">
                        {{ trans('forum.moderation.delete_post') }}
                    </button>
                </form>
            {% endif %}
        </div>
    </div>
    <div class="prose prose-zinc mt-3 max-w-none text-sm dark:prose-invert">{{ post.body_html|raw }}</div>
    {% if post.is_edited %}
        <p class="mt-3 text-xs text-zinc-500 dark:text-zinc-500">{{ trans('forum.post.edited') }} {{ post.edited_at }}</p>
    {% endif %}
</article>
