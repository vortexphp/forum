<article class="rounded-xl border border-zinc-200 bg-white p-4 dark:border-zinc-800 dark:bg-zinc-900/60">
    <div class="flex items-start justify-between gap-3">
        <div>
            <a href="{{ route('forum.thread.show', { category: category.slug, thread: thread.slug }) }}" class="text-base font-semibold text-zinc-900 hover:text-emerald-600 dark:text-white dark:hover:text-emerald-400">
                {{ thread.title }}
            </a>
            <p class="mt-1 text-xs text-zinc-500 dark:text-zinc-500">
                {{ trans('forum.thread.by') }} <a href="{{ route('profile.show', { user: thread.user_id }) }}" class="font-semibold hover:text-emerald-600 dark:hover:text-emerald-400">{{ thread.author_name }}</a>
                {% if thread.author_primary_badge is defined and thread.author_primary_badge %}
                    <span class="ml-1 rounded bg-sky-100 px-1.5 py-0.5 text-[10px] font-semibold text-sky-800 dark:bg-sky-900/35 dark:text-sky-300">{{ trans('badges.' ~ thread.author_primary_badge) }}</span>
                {% elseif thread.author_role == 'moderator' %}
                    <span class="ml-1 rounded bg-violet-100 px-1.5 py-0.5 text-[10px] font-semibold text-violet-800 dark:bg-violet-900/35 dark:text-violet-300">{{ trans('forum.moderation.badge') }}</span>
                {% endif %}
                · {{ thread.created_at }}
            </p>
        </div>
        <div class="flex flex-wrap items-center gap-1">
            {% if thread.is_pinned %}
                <span class="rounded bg-emerald-100 px-2 py-0.5 text-[11px] font-semibold text-emerald-800 dark:bg-emerald-900/35 dark:text-emerald-300">{{ trans('forum.thread.sticky') }}</span>
            {% endif %}
            {% if thread.is_locked %}
                <span class="rounded bg-amber-100 px-2 py-0.5 text-[11px] font-semibold text-amber-800 dark:bg-amber-900/35 dark:text-amber-300">{{ trans('forum.thread.locked') }}</span>
            {% endif %}
        </div>
    </div>
    <div class="mt-3 flex flex-wrap items-center gap-2 text-xs text-zinc-500 dark:text-zinc-500">
        <span>{{ trans('forum.thread.reply_count', { count: thread.reply_count|default(0) }) }}</span>
        {% if thread.last_post_at %}
            <span>·</span>
            <span class="inline-flex items-center gap-1.5">
                {% if thread.last_comment_author_avatar is defined and thread.last_comment_author_avatar %}
                    <img src="{{ public_url(thread.last_comment_author_avatar) }}" alt="{{ thread.last_comment_author_name|default('User') }}" class="h-4 w-4 rounded-full object-cover ring-1 ring-zinc-200 dark:ring-zinc-700" width="16" height="16">
                {% elseif thread.last_comment_author_name is defined and thread.last_comment_author_name %}
                    <span class="inline-flex h-4 w-4 items-center justify-center rounded-full bg-zinc-200 text-[9px] font-semibold text-zinc-700 dark:bg-zinc-700 dark:text-zinc-200">{{ thread.last_comment_author_name|slice(0, 1)|upper }}</span>
                {% endif %}
                <span>{{ trans('forum.thread.last_post') }} {{ thread.last_post_at }}</span>
                {% if thread.last_comment_author_primary_badge is defined and thread.last_comment_author_primary_badge %}
                    <span class="rounded bg-sky-100 px-1.5 py-0.5 text-[10px] font-semibold text-sky-800 dark:bg-sky-900/35 dark:text-sky-300">{{ trans('badges.' ~ thread.last_comment_author_primary_badge) }}</span>
                {% endif %}
            </span>
        {% endif %}
    </div>
</article>
