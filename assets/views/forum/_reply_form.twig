{% if authUser is not null %}
    {% if not thread.is_locked or authUser.role == 'moderator' %}
        <form
            method="post"
            action="{{ route('forum.post.store', { category: category.slug, thread: thread.slug }) }}"
            class="rounded-xl border border-zinc-200 bg-white p-4 dark:border-zinc-800 dark:bg-zinc-900/60"
            data-reply-form
            data-label-like="{{ trans('forum.likes.button') }}"
            data-label-flag-post="{{ trans('forum.flags.flag_post') }}"
            data-label-edit-post="{{ trans('forum.post.edit') }}"
            data-label-delete-post="{{ trans('forum.moderation.delete_post') }}"
            data-label-moderation-badge="{{ trans('forum.moderation.badge') }}"
            data-label-reply-required="{{ trans('forum.validation.reply_required') }}"
            data-csrf-token="{{ csrfToken|default('') }}"
        >
            <input type="hidden" name="_csrf" value="{{ csrfToken|default('') }}">
            <label for="reply-body" class="mb-2 block text-sm font-medium text-zinc-700 dark:text-zinc-300">{{ trans('forum.reply.label') }}</label>
            <textarea id="reply-body" name="body" rows="6" class="js-markdown-editor w-full rounded-lg border border-zinc-300 bg-white px-3 py-2 text-sm text-zinc-900 outline-none ring-emerald-500 focus:ring dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100">{{ old.body|default('') }}</textarea>
            <p class="mt-2 hidden text-xs text-rose-600 dark:text-rose-400" data-reply-form-error></p>
            {% if errors.body is defined %}
                <p class="mt-2 text-xs text-rose-600 dark:text-rose-400">{{ errors.body }}</p>
            {% endif %}
            <p class="mt-2 hidden text-xs text-emerald-700 dark:text-emerald-300" data-reply-form-status></p>
            <div class="mt-3">
                <button type="submit" class="rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow hover:bg-emerald-500" data-reply-submit-button>
                    {{ trans('forum.reply.submit') }}
                </button>
            </div>
        </form>
    {% else %}
        <div class="rounded-lg border border-amber-300 bg-amber-50 p-3 text-sm text-amber-800 dark:border-amber-900/40 dark:bg-amber-900/20 dark:text-amber-300">{{ trans('forum.thread.locked') }}</div>
    {% endif %}
{% else %}
    <div class="rounded-lg border border-zinc-200 bg-white p-4 text-sm text-zinc-600 dark:border-zinc-800 dark:bg-zinc-900/60 dark:text-zinc-400">
        {{ trans('forum.reply.sign_in_prompt') }} <a href="/login" class="font-semibold text-emerald-700 hover:text-emerald-600 dark:text-emerald-400 dark:hover:text-emerald-300">{{ trans('nav.sign_in') }}</a>.
    </div>
{% endif %}
